# Firebase web app config — grab these from Firebase Console → Project settings → Your apps → Web.
# All values are safe to ship in the bundled client code (Firebase security is enforced via Firestore rules + Auth).
# Prefix MUST be VITE_ for Vite to expose them to the client.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
